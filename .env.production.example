# Production Environment Variables
# Copy this file to .env.production and fill in your values

# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# Your production URL (e.g., https://openschemaextract.com)
AUTH_URL=https://your-domain.com

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
# Authorization callback URL: https://your-domain.com/api/auth/callback/github
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret

# MongoDB connection (leave as-is for docker-compose)
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DB=openschemaextract

# OAuth 2.1 Authorization Server
OAUTH_ISSUER=https://your-domain.com
# Generate with: openssl rand -base64 32
OAUTH_JWT_SECRET=your-oauth-jwt-secret-here
